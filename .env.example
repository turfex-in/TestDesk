# Firebase — get these from your Firebase project settings → General → Your apps → Web app → SDK setup
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Gemini — get from https://aistudio.google.com/app/apikey (free tier works)
# NOTE: this ships to the browser. For production, proxy via a Firebase Cloud Function.
VITE_GEMINI_API_KEY=
