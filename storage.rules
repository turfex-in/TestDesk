rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // All bug/comment screenshots require sign-in. Anyone signed in can read
    // (so developers and testers can see each other's evidence) but only the
    // uploader can write files up to 10 MB under bugs/ and comments/.
    match /bugs/{projectId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /comments/{projectId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
